# DATABRICKS_TOKEN: Required for Databricks LLM API calls.
DATABRICKS_TOKEN="your_databricks_token"

# DATABRICKS_WORKSPACE_URL: The base URL of your Databricks workspace.
DATABRICKS_WORKSPACE_URL="https://adb-xxx.azuredatabricks.net"

# GEMINI_API_KEY: Used as a fallback for the Databricks LLM simulation.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
